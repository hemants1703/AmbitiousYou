# Backend environment — copy to .env.development (local) and set real values.
# In production/dev DEPLOYMENTS these are injected by the orchestrator
# (VPS: /opt/ambitiousyou/<env>/backend.env, and the CI migrate step), NEVER
# committed. .env.production is gitignored — keep it that way.

# API port (defaults to 3001 if unset)
PORT=3001

# Frontend origin used to build links inside transactional emails
# (verify, reset, dashboard). Per environment:
#   local : http://localhost:3000
#   dev   : https://dev.ambitiousyou.pro
#   prod  : https://www.ambitiousyou.pro
APP_BASE_URL=http://localhost:3000

# Postgres connection string (Drizzle runtime + drizzle-kit CLI).
#   local : postgresql://postgres:postgres@localhost:5432/ambitiousyou_dev?schema=public
#   cloud : use the Supabase SESSION pooler (IPv4, port 5432), NOT the IPv6
#           direct host, and append ?sslmode=require :
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ambitiousyou_dev?schema=public

# Azure Communication Services — transactional email. Optional: if unset the
# backend logs a warning and disables outbound email.
AZURE_CONNECTION_STRING="endpoint=https://<region>.communication.azure.com/;accesskey=<key>"
