generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AmbitionTrackingMethod {
  task
  milestone
}

enum AmbitionStatus {
  active
  completed
  missed
}

enum AmbitionPriority {
  low
  medium
  high
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  passwordHash  String   @map("password_hash")
  image         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions   Session[]
  ambitions  Ambition[]
  tasks      Task[]
  milestones Milestone[]
  notes      Note[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address") @db.VarChar(255)
  userAgent String?  @map("user_agent") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  identifier String   @db.VarChar(255)
  value      String   @db.VarChar(255)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("verifications")
}

model Ambition {
  id                          String                 @id @default(uuid()) @db.Uuid
  userId                      String                 @map("user_id") @db.Uuid
  ambitionName                String                 @map("ambition_name") @db.VarChar(255)
  ambitionDefinition          String?                @map("ambition_definition") @db.Text
  ambitionTrackingMethod      AmbitionTrackingMethod @map("ambition_tracking_method")
  ambitionStartDate           DateTime               @map("ambition_start_date")
  ambitionEndDate             DateTime               @map("ambition_end_date")
  ambitionCompletionDate      DateTime?              @map("ambition_completion_date")
  ambitionStatus              AmbitionStatus         @default(active) @map("ambition_status")
  ambitionPriority            AmbitionPriority       @default(medium) @map("ambition_priority")
  ambitionPercentageCompleted Int                    @default(0) @map("ambition_percentage_completed")
  isFavourited                Boolean                @default(false) @map("is_favourited")
  createdAt                   DateTime               @default(now()) @map("created_at")
  updatedAt                   DateTime               @updatedAt @map("updated_at")

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks      Task[]
  milestones Milestone[]
  notes      Note[]

  @@map("ambitions")
}

model Task {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  ambitionId      String   @map("ambition_id") @db.Uuid
  task            String   @db.VarChar(255)
  taskDescription String?  @map("task_description") @db.Text
  taskCompleted   Boolean  @default(false) @map("task_completed")
  taskDeadline    DateTime @map("task_deadline") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ambition Ambition @relation(fields: [ambitionId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

model Milestone {
  id                   String   @id @default(uuid()) @db.Uuid
  userId               String   @map("user_id") @db.Uuid
  ambitionId           String   @map("ambition_id") @db.Uuid
  milestone            String   @db.VarChar(255)
  milestoneDescription String?  @map("milestone_description") @db.Text
  milestoneCompleted   Boolean  @default(false) @map("milestone_completed")
  milestoneTargetDate  DateTime @map("milestone_target_date")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ambition Ambition @relation(fields: [ambitionId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model Note {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  ambitionId String   @map("ambition_id") @db.Uuid
  note       String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ambition Ambition @relation(fields: [ambitionId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Settings {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  userTimezone          String   @map("user_timezone") @db.VarChar(255)
  emailAccountActivity  Boolean  @default(false) @map("email_account_activity")
  pushAmbitionReminders Boolean  @default(false) @map("push_ambition_reminders")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("settings")
}
