# Frontend environment — copy to .env.local (local) and set real values.
# In production/dev DEPLOYMENTS these are injected by the orchestrator
# (Vercel project env vars), NEVER committed. .env.local is gitignored.

# Backend REST API base URL (server-side only — used by Server Actions and
# RSC data fetches). Per environment:
#   local : http://localhost:3001
#   dev   : https://api.dev.ambitiousyou.pro
#   prod  : https://api.ambitiousyou.pro
API_URL=http://localhost:3001

# Canonical site URL for SEO metadata, sitemap, and Open Graph. Optional locally
# (defaults to https://www.ambitiousyou.pro). Set explicitly on preview
# deployments so canonical URLs match the preview hostname.
#   local : http://localhost:3000
#   dev   : https://dev.ambitiousyou.pro
#   prod  : https://www.ambitiousyou.pro
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: emit Content-Security-Policy-Report-Only instead of enforcing CSP.
# Set to 1 on a preview deployment first, click through every page (both themes
# + login/signup round-trip), then unset to enforce. See next.config.ts.
# CSP_REPORT_ONLY=1
